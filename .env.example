# Copy to .env.local and fill in from Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Production site URL (for email confirmation links). Local dev can omit.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Do not enable on public production (uses service role on home page).
# ENABLE_PUBLIC_AUTO_SEED=false

# Optional: Playwright E2E (remove .skip in tests/e2e/*.spec.ts)
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
